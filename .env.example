# Server
PORT=3000
NODE_ENV=development

# Supabase / PostgreSQL
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# Blockchain (Base Testnet / Sepolia)
RPC_URL=https://sepolia.base.org
CHAIN_ID=84532

# Block Explorer (optional — enriches deposit records with tx hash)
# Defaults to Blockscout (free, no key required)
EXPLORER_API_KEY=
EXPLORER_API_URL=https://base-sepolia.blockscout.com/api

# Encryption
ENCRYPTION_KEY=your-32-byte-hex-encryption-key

# JWT
JWT_SECRET=your-jwt-secret
JWT_EXPIRES_IN=24h

# Sweep
SWEEP_THRESHOLD=0.001
# SWEEP_CRON=*/5 * * * *
HOT_WALLET_ADDRESS=0xYourHotWalletAddress
HOT_WALLET_PRIVATE_KEY=encrypted-hot-wallet-private-key
